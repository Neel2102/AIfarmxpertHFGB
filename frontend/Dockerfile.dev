# Development Dockerfile for React frontend with hot-reloading
FROM node:18-alpine

# Set working directory
WORKDIR /app

# Install curl for docker healthchecks
RUN apk add --no-cache curl

# Copy package files
COPY package*.json ./

# Install dependencies
RUN npm install

# Copy source code
COPY . .

# Expose port
EXPOSE 3000

# Start development server with hot-reloading
CMD ["npm", "start"]
